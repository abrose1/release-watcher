# This repo's Railway Postgres
DATABASE_URL=postgresql://user:pass@host:5432/release_watcher

# For ``scripts/sync_creators_remote.py`` or local alembic against Railway: same DB via **public** URL.
DATABASE_PUBLIC_URL=

# Public URL of taste-profile Railway Postgres (separate Railway project)
TASTE_PROFILE_DATABASE_URL=postgresql://user:pass@host:5432/taste_profile

# Spotify Developer App (same app as taste-profile repo)
# Only Client Credentials are needed here (client_id + client_secret).
# SPOTIFY_REFRESH_TOKEN is only required by the taste-profile intake scripts, not this service.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# TMDB API (free at themoviedb.org)
TMDB_API_KEY=your_tmdb_api_key

# Google Books API (free at console.cloud.google.com)
GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# Brave Search API (free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
YOUR_PHONE_NUMBER=+1234567890

# Optional — merge into preferences.* on top of config.yaml (omit if you only use YAML override file)
SMS_GREETING_NAME=
SMS_FIRST_NAME=
SPOTIFY_SEED_PLAYLIST_IDS=id1,id2,id3
FILM_TASTE=
FILM_TMDB_GENRE_IDS=18,53,878
SMS_QUIET_TIMEZONE=America/Los_Angeles